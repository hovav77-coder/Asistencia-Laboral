# ======================================================================
#  Variables de entorno — copia este archivo a .env.local para desarrollo
#  y configura las MISMAS variables en Vercel (Project Settings > Environment Variables).
#  NUNCA subas .env.local ni las credenciales al repositorio.
# ======================================================================

# Código de acceso compartido que pide la app al entrar.
ACCESS_CODE=cambia-esto-por-un-codigo-secreto

# Secreto para firmar la cookie de sesión (usa una cadena larga y aleatoria).
# Puedes generar una con:  openssl rand -base64 32
SESSION_SECRET=cadena-larga-y-aleatoria-para-firmar-sesiones

# --- Google Sheets (cuenta de servicio) ---
# Email de la cuenta de servicio (termina en .iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=nombre@tu-proyecto.iam.gserviceaccount.com

# Clave privada de la cuenta de servicio.
# Copia el valor "private_key" del JSON. Debe ir entre comillas y con los \n literales.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ID de la Hoja de Google (lo que va entre /d/ y /edit en la URL).
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz1234567890

# Jornada estándar en horas (para convertir ausencias por horas a días equivalentes).
STANDARD_WORKDAY_HOURS=8
